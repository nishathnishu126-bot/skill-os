{
  "manifest_version": 3,
  "name": "SkillOS Tracker",
  "version": "1.0.0",
  "description": "Automatically tracks your learning activity across YouTube, Udemy, Coursera, freeCodeCamp, and Medium.",

  "permissions": ["storage", "tabs", "alarms", "notifications"],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.udemy.com/*",
    "https://www.coursera.org/*",
    "https://www.freecodecamp.org/*",
    "https://medium.com/*",
    "http://localhost:8000/*"
  ],

  "background": { "service_worker": "background.js" },

  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },

  "content_scripts": [
    { "matches": ["https://www.youtube.com/*"], "js": ["youtube.js"], "run_at": "document_idle" },
    { "matches": ["https://www.udemy.com/*"], "js": ["udemy.js"], "run_at": "document_idle" },
    { "matches": ["https://www.coursera.org/*"], "js": ["coursera.js"], "run_at": "document_idle" },
    { "matches": ["https://www.freecodecamp.org/*"], "js": ["freecodecamp.js"], "run_at": "document_idle" },
    { "matches": ["https://medium.com/*"], "js": ["medium.js"], "run_at": "document_idle" }
  ],

  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
}
